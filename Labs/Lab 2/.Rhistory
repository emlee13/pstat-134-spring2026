younger <- engagement_data %>% filter(Age <= 20)
older <- engagement_data %>% filter(Age >= 50)
# 2. Calculate percentages for Younger users
young_vid <- younger %>%
count(Video.Category) %>%
mutate(Younger_Pct = (n / sum(n)) * 100) %>%
select(-n)
View(young_vid)
summary(engagement_data$Video.Category)
# 3. Calculate percentages for Older users
old_vid <- older %>%
count(Video.Category) %>%
mutate(Older_Pct = (n / sum(n)) * 100) %>%
select(-n)
# 4. Combine into one table and print
vid_comparison <- full_join(young_vid, old_vid, by = "Video.Category") %>%
replace_na(list(Younger_Pct = 0, Older_Pct = 0)) %>%
arrange(desc(Younger_Pct))
print(vid_comparison)
vid_comparison <- full_join(young_vid, old_vid, by = "Video.Category")
print(vid_comparison)
young_vid <- younger %>%
count(Video.Category)
full_join(young_vid, old_vid, by = "Video.Category")
vid_comparison <- full_join(young_vid, old_vid, by = "Video.Category")
print(vid_comparison)
young_vid <- younger %>%
count(Video.Category) %>%
mutate(Younger_Pct = (n / sum(n)) * 100) %>%
select(-n)
old_vid <- older %>%
count(Video.Category) %>%
mutate(Older_Pct = (n / sum(n)) * 100) %>%
select(-n)
full_join(young_vid, old_vid, by = "Video.Category")
young_plat <- younger %>%
count(Platform) %>%
mutate(Younger_Pct = (n / sum(n)) * 100) %>%
select(-n)
old_plat <- older %>%
count(Platform) %>%
mutate(Older_Pct = (n / sum(n)) * 100) %>%
select(-n)
full_join(young_plat, old_plat, by = "Platform")
